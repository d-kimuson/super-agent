{
  "name": "@kimuson/super-agent",
  "version": "0.0.0",
  "description": "FIXME",
  "license": "MIT",
  "bin": {
    "super-agent": "./dist/cli/index.mjs"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    "./cli": {
      "require": "./dist/cli/index.cjs",
      "import": "./dist/cli/index.mjs"
    },
    "./sdk": {
      "require": "./dist/sdk.cjs",
      "import": "./dist/sdk.mjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "cli": "pnpm tsx ./src/cli/index.ts",
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "lint": "run-s 'lint:*'",
    "lint:oxlint": "oxlint --type-aware --type-check --ignore-path .gitignore --report-unused-disable-directives --tsconfig ./tsconfig.json",
    "lint:oxfmt": "pnpm fix:oxfmt --check",
    "fix": "run-s 'fix:*'",
    "fix:oxlint": "pnpm lint:oxlint --fix --fix-suggestions --fix-dangerously",
    "fix:oxfmt": "oxfmt --ignore-path .gitignore --no-error-on-unmatched-pattern",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.2.7",
    "@github/copilot-sdk": "0.1.18",
