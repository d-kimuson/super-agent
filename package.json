    "zod": "4.3.5",
    "zod-to-json-schema": "3.25.1"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "0.71.2",
    "@tsconfig/strictest": "2.0.8",
    "@types/inquirer": "9.0.9",
